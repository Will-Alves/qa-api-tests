              "\r",
              "// 🔹 Função recursiva\r",
              "function logJson(obj, path = \"\") {\r",
              "\r",
              "    if (Array.isArray(obj)) {\r",
              "\r",
              "        obj.forEach((item, index) => {\r",
              "            logJson(item, `${path}[${index}]`);\r",
              "        });\r",
              "\r",
              "    } else if (typeof obj === \"object\" && obj !== null) {\r",
              "\r",
              "        Object.keys(obj).forEach(key => {\r",
              "            logJson(obj[key], path ? `${path}.${key}` : key);\r",
              "        });\r",
              "\r",
              "    } else {\r",
              "        // 🔥 aqui cria um teste pra cada valor\r",
              "        pm.test(`${path} → ${obj}`, () => {\r",
              "            pm.expect(obj).to.not.be.undefined;\r",
              "        });\r",
              "    }\r",
              "}\r",
              "\r",
              "// 🚀 EXECUTA\r",
              "logJson(json);"
            ],
