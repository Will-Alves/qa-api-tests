    {
      "name": "ConsultarPaciente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ══════════════════════════════════════════════════════",
              "// 🔧 SETUP + FAIL FAST (CRÍTICO)",
              "// ══════════════════════════════════════════════════════",
              "",
              "let json;",
              "",
              "pm.test(\"Response deve ser JSON válido\", () => {",
              "    json = pm.response.json();",
              "    pm.expect(json).to.be.an(\"object\");",
              "});",
              "",
              "let contratoValido = false;",
              "",
              "pm.test(\"Contrato deve conter Objeto e Resposta\", () => {",
              "    contratoValido =",
              "        json &&",
              "        Array.isArray(json.Objeto) &&",
              "        Array.isArray(json.Resposta);",
              "",
              "    pm.expect(contratoValido, \"Contrato inválido\").to.be.true;",
              "});",
              "",
              "// 🔒 BLOQUEIA EXECUÇÃO CASO CONTRATO QUEBRE",
              "if (!contratoValido) {",
              "    console.error(\"⛔ Execução interrompida: contrato inválido\");",
              "    return;",
              "}",
              "",
              "const p = json.Objeto[0];",
              "",
              "pm.test(\"Paciente deve existir\", () => {",
              "    pm.expect(p, \"Objeto[0] não encontrado\").to.exist;",
              "});",
              "",
              "if (!p) {",
              "    console.error(\"⛔ Execução interrompida: paciente não encontrado\");",
              "    return;",
              "}",
              "",
              "// ══════════════════════════════════════════════════════",
              "// 🧩 HELPERS",
              "// ══════════════════════════════════════════════════════",
              "",
              "function assertString(field, name) {",
              "    pm.expect(field, `${name} deve ser string`).to.be.a(\"string\").and.not.empty;",
              "}",
              "",
              "function assertNumber(field, name) {",
              "    pm.expect(field, `${name} deve ser number`).to.be.a(\"number\");",
              "}",
              "",
              "function assertBoolean(field, name) {",
              "    pm.expect(field, `${name} deve ser boolean`).to.be.a(\"boolean\");",
              "}",
              "",
              "function assertArray(field, name) {",
              "    pm.expect(field, `${name} deve ser array`).to.be.an(\"array\");",
              "}",
              "",
              "function calcularIdade(dataNascimento) {",
              "    const hoje = new Date();",
              "    const nasc = new Date(dataNascimento);",
              "",
              "    let idade = hoje.getFullYear() - nasc.getFullYear();",
              "    const m = hoje.getMonth() - nasc.getMonth();",
              "",
              "    if (m < 0 || (m === 0 && hoje.getDate() < nasc.getDate())) {",
              "        idade--;",
              "    }",
              "",
              "    return idade;",
              "}",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-01 · CONTRATO HTTP",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"HTTP 200\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Tempo < 2s\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Content-Type JSON\", () => {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/json\");",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-02 · ESTRUTURA",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"Objeto deve ter ao menos 1 item\", () => {",
              "    pm.expect(json.Objeto.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Resposta.Status deve ser 1\", () => {",
              "    pm.expect(json.Resposta[0].Status).to.equal(1);",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-03 · IDENTIFICAÇÃO (GENÉRICO)",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"NumProntuario válido\", () => {",
              "    assertNumber(p.NumProntuario, \"NumProntuario\");",
              "});",
              "",
              "pm.test(\"CPF válido (11 dígitos)\", () => {",
              "    pm.expect(String(p.NumCPF)).to.match(/^\\d{11}$/);",
              "});",
              "",
              "pm.test(\"Nome válido\", () => {",
              "    assertString(p.NomePessoa, \"NomePessoa\");",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-04 · DEMOGRAFIA",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"DataNascimento válida\", () => {",
              "    pm.expect(p.DataNascimento).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "});",
              "",
              "pm.test(\"Idade consistente\", () => {",
              "    const idade = calcularIdade(p.DataNascimento);",
              "    pm.expect(p.Idade).to.eql(idade);",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-05 · SEXO / GÊNERO",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"Sexo válido\", () => {",
              "    assertNumber(p.SexoDR, \"SexoDR\");",
              "    assertString(p.DescSexo, \"DescSexo\");",
              "});",
              "",
              "pm.test(\"⚠️ Alerta: Nome vs Sexo\", () => {",
              "    const inconsistente =",
              "        /^WILLIAM/i.test(p.NomePessoa) &&",
              "        p.DescSexo === \"Feminino\";",
              "",
              "    pm.expect(inconsistente, \"Possível inconsistência de cadastro\").to.be.false;",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-06 · CONTATO",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"Celular válido\", () => {",
              "    assertNumber(p.NumFoneCelular, \"NumFoneCelular\");",
              "});",
              "",
              "pm.test(\"Email válido\", () => {",
              "    if (p.EmailPessoal) {",
              "        pm.expect(p.EmailPessoal)",
              "            .to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
              "    }",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-07 · ENDEREÇO",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"CEP válido\", () => {",
              "    pm.expect(p.CodCep).to.match(/^\\d{8}$/);",
              "});",
              "",
              "pm.test(\"Cidade/Estado válidos\", () => {",
              "    assertString(p.DescCidade, \"DescCidade\");",
              "    assertString(p.DescEstado, \"DescEstado\");",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-08 · ICONOGRAFIA",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"ListaIconografia válida\", () => {",
              "    assertArray(p.ListaIconografia, \"ListaIconografia\");",
              "",
              "    p.ListaIconografia.forEach((ic, i) => {",
              "        assertNumber(ic.IdTabela, `IdTabela[${i}]`);",
              "        assertString(ic.DescIconografia, `DescIconografia[${i}]`);",
              "        assertBoolean(ic.Ativo, `Ativo[${i}]`);",
              "    });",
              "});",
              "",
              "pm.test(\"⚠️ Paciente não deve estar como falecido\", () => {",
              "    const falecido = p.ListaIconografia.some(",
              "        ic => ic.DescIconografia === \"Paciente Falecido\" && ic.Ativo",
              "    );",
              "",
              "    pm.expect(falecido, \"Paciente marcado como falecido\").to.be.false;",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// CT-09 · ANOMALIAS",
              "// ══════════════════════════════════════════════════════",
              "",
              "pm.test(\"DataObito não pode ser futura\", () => {",
              "    if (p.DataObito) {",
              "        const obito = new Date(p.DataObito);",
              "        pm.expect(obito.getTime()).to.be.below(Date.now());",
              "    }",
              "});",
              "",
              "pm.test(\"DataInclusao não pode ser futura\", () => {",
              "    const inclusao = new Date(p.DataInclusao);",
              "    pm.expect(inclusao.getTime()).to.be.at.most(Date.now());",
              "});",
              "",
              "// ══════════════════════════════════════════════════════",
              "// 📊 LOG",
              "// ══════════════════════════════════════════════════════",
              "",
              "console.info(\"Paciente OK:\", {",
              "    nome: p.NomePessoa,",
              "    prontuario: p.NumProntuario,",
              "    idade: p.Idade",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const correlationId = pm.variables.replaceIn(\"{{$guid}}\");\r",
              "const dataHoraExecucao = new Date().toISOString();\r",
              "\r",
              "pm.variables.set(\"correlationId\", correlationId);\r",
              "pm.variables.set(\"dataHoraExecucao\", dataHoraExecucao);\r",
              "\r",
              "// Garante headers padrão\r",
              "pm.request.headers.upsert({\r",
              "    key: \"Content-Type\",\r",
              "    value: \"application/json\"\r",
              "});\r",
              "\r",
              "pm.request.headers.upsert({\r",
              "    key: \"X-Correlation-Id\",\r",
              "    value: correlationId\r",
              "});\r",
              "\r",
              "// Valida se existe body raw\r",
              "const rawBody = pm.request.body?.raw;\r",
              "if (!rawBody || !rawBody.trim()) {\r",
              "    throw new Error(\"O body da requisição está vazio.\");\r",
              "}\r",
              "\r",
              "// Faz parse do JSON\r",
              "let body;\r",
              "try {\r",
              "    body = JSON.parse(rawBody);\r",
              "} catch (error) {\r",
              "    throw new Error(\"O body da requisição não contém um JSON válido.\");\r",
              "}\r",
              "\r",
              "// Campos aceitos\r",
              "const numProntuario = body.NumProntuario;\r",
              "const numCPF = body.NumCPF;\r",
              "\r",
              "// Exige ao menos um dos campos\r",
              "if (!numProntuario && !numCPF) {\r",
              "    throw new Error(\"Informe 'NumProntuario' ou 'NumCPF' no body da requisição.\");\r",
              "}\r",
              "\r",
              "// Validação de NumProntuario\r",
              "if (numProntuario !== undefined && numProntuario !== null) {\r",
              "    if (typeof numProntuario !== \"string\" && typeof numProntuario !== \"number\") {\r",
              "        throw new Error(\"O campo 'NumProntuario' deve ser texto ou número.\");\r",
              "    }\r",
              "\r",
              "    if (String(numProntuario).trim() === \"\") {\r",
              "        throw new Error(\"O campo 'NumProntuario' não pode estar vazio.\");\r",
              "    }\r",
              "}\r",
              "\r",
              "// Validação de NumCPF\r",
              "if (numCPF !== undefined && numCPF !== null) {\r",
              "    if (typeof numCPF !== \"string\" && typeof numCPF !== \"number\") {\r",
              "        throw new Error(\"O campo 'NumCPF' deve ser texto ou número.\");\r",
              "    }\r",
              "\r",
              "    const cpfLimpo = String(numCPF).replace(/\\D/g, \"\");\r",
              "\r",
              "    if (cpfLimpo.length !== 11) {\r",
              "        throw new Error(\"O campo 'NumCPF' deve conter 11 dígitos.\");\r",
              "    }\r",
              "}\r",
              "\r",
              "console.log(\"Requisição preparada com sucesso.\");\r",
              "console.log(\"Correlation ID:\", correlationId);\r",
              "console.log(\"Data/Hora execução:\", dataHoraExecucao);\r",
              "console.log(\"URL final:\", pm.variables.replaceIn(pm.request.url.toString()));\r",
              "console.log(\"Body enviado:\", body);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
