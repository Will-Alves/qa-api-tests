    {
      "name": "ConsultarPassagemCheckup",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "\r",
              "// 🔹 Função recursiva\r",
              "function logJson(obj, path = \"\") {\r",
              "\r",
              "    if (Array.isArray(obj)) {\r",
              "\r",
              "        obj.forEach((item, index) => {\r",
              "            logJson(item, `${path}[${index}]`);\r",
              "        });\r",
              "\r",
              "    } else if (typeof obj === \"object\" && obj !== null) {\r",
              "\r",
              "        Object.keys(obj).forEach(key => {\r",
              "            logJson(obj[key], path ? `${path}.${key}` : key);\r",
              "        });\r",
              "\r",
              "    } else {\r",
              "        // 🔥 aqui cria um teste pra cada valor\r",
              "        pm.test(`${path} → ${obj}`, () => {\r",
              "            pm.expect(obj).to.not.be.undefined;\r",
              "        });\r",
              "    }\r",
              "}\r",
              "\r",
              "// 🚀 EXECUTA\r",
              "logJson(json);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"cpf\": \"12345678900\",\r\n  \"data\": \"2026-04-08\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://192.168.0.196:9000/apidev?cenario=36&recurso=consultarpassagemcheckup1",
          "protocol": "http",
          "host": [
            "192",
